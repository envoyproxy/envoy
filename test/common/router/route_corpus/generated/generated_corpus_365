goo.gle/debugproto    
config {
  virtual_hosts {
    name: "www2"
    domains: "www.example.com"
    routes {
      match {
        prefix: "/"
      }
      route {
        cluster: "whatever"
      }
    }
  }
}
headers {
  headers {
    key: ":authority"
    value: "www.example.com"
  }
  headers {
    key: ":path"
    value: "/foo"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
}
