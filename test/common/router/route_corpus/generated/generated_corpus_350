goo.gle/debugproto
config {
  virtual_hosts {
    name: "bar"
    domains: "*"
    matcher {
      matcher_tree {
        input {
          name: "request-headers"
          typed_config {
            [type.googleapis.com/envoy.type.matcher.v3.HttpRequestHeaderMatchInput] {
              header_name: ":path"
            }
          }
        }
        prefix_match_map {
          map {
            key: "/foo"
            value {
              action {
                name: "route"
                typed_config {
                  [type.googleapis.com/envoy.config.route.v3.RouteList] {
                    routes {
                      match {
                        prefix: "/foo/bar/baz"
                      }
                      route {
                        cluster: "foo_bar_baz"
                      }
                    }
                    routes {
                      match {
                        prefix: "/foo/bar"
                      }
                      route {
                        cluster: "foo_bar"
                      }
                    }
                    routes {
                      match {
                        prefix: "/foo"
                      }
                      route {
                        cluster: "foo"
                      }
                    }
                    routes {
                      match {
                        prefix: "/foo/default"
                      }
                      route {
                        cluster: "default"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
headers {
  headers {
    key: ":authority"
    value: "bat.com"
  }
  headers {
    key: ":path"
    value: "/foo/bar"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
}
