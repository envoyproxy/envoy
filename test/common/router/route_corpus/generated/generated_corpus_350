goo.gle/debugproto    
config {
  virtual_hosts {
    name: "local_service"
    domains: "*"
    routes {
      match {
        prefix: "/foo"
      }
      route {
        cluster: "local_service_grpc"
        max_grpc_timeout {
          nanos: 100000000
        }
        grpc_timeout_offset {
          nanos: 10000000
        }
      }
    }
    routes {
      match {
        prefix: "/"
      }
      route {
        cluster_header: "request_to"
        max_grpc_timeout {
          nanos: 200000000
        }
        grpc_timeout_offset {
          nanos: 20000000
        }
      }
    }
  }
}
headers {
  headers {
    key: ":authority"
    value: "www.lyft.com"
  }
  headers {
    key: ":path"
    value: "/foo"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
}
