goo.gle/debugproto
config {
  virtual_hosts {
    name: "www2"
    domains: "www.lyft.com"
    routes {
      match {
        prefix: "/new_endpoint"
      }
      route {
        cluster: "www2"
        prefix_rewrite: "/api/new_endpoint"
      }
      response_headers_to_add {
        header {
          key: "x-route-header"
          value: "route-override"
        }
        append_action: OVERWRITE_IF_EXISTS_OR_ADD
      }
      response_headers_to_add {
        header {
          key: "x-global-header1"
          value: "route-override"
        }
        append_action: OVERWRITE_IF_EXISTS_OR_ADD
      }
      response_headers_to_add {
        header {
          key: "x-vhost-header1"
          value: "route-override"
        }
        append_action: OVERWRITE_IF_EXISTS_OR_ADD
      }
    }
    routes {
      match {
        path: "/"
      }
      route {
        cluster: "root_www2"
      }
      response_headers_to_add {
        header {
          key: "x-route-header"
          value: "route-allpath"
        }
        append_action: OVERWRITE_IF_EXISTS_OR_ADD
      }
      response_headers_to_remove: "x-route-remove"
    }
    routes {
      match {
        prefix: "/"
      }
      route {
        cluster: "www2"
      }
    }
    response_headers_to_add {
      header {
        key: "x-global-header1"
        value: "vhost-override"
      }
      append_action: OVERWRITE_IF_EXISTS_OR_ADD
    }
    response_headers_to_add {
      header {
        key: "x-vhost-header1"
        value: "vhost1-www2"
      }
      append_action: OVERWRITE_IF_EXISTS_OR_ADD
    }
    response_headers_to_remove: "x-vhost-remove"
  }
  virtual_hosts {
    name: "www2_staging"
    domains: "www-staging.lyft.net"
    routes {
      match {
        prefix: "/"
      }
      route {
        cluster: "www2_staging"
      }
      response_headers_to_add {
        header {
          key: "x-route-header"
          value: "route-allprefix"
        }
        append_action: OVERWRITE_IF_EXISTS_OR_ADD
      }
    }
    response_headers_to_add {
      header {
        key: "x-vhost-header1"
        value: "vhost1-www2_staging"
      }
      append_action: OVERWRITE_IF_EXISTS_OR_ADD
    }
  }
  virtual_hosts {
    name: "default"
    domains: "*"
    routes {
      match {
        prefix: "/"
      }
      route {
        cluster: "instant-server"
      }
    }
  }
  internal_only_headers: "x-lyft-user-id"
  response_headers_to_add {
    header {
      key: "x-global-header1"
      value: "global1"
    }
    append_action: OVERWRITE_IF_EXISTS_OR_ADD
  }
  response_headers_to_remove: "x-global-remove"
  most_specific_header_mutations_wins: true
}
headers {
  headers {
    key: ":authority"
    value: "www.lyft.com"
  }
  headers {
    key: ":path"
    value: "/new_endpoint/foo"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
}
