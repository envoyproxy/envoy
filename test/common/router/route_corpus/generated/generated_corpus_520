goo.gle/debugproto    
config {
  virtual_hosts {
    name: "www"
    domains: "www.lyft.com"
    routes {
      match {
        prefix: "/foo"
      }
      route {
        cluster: "www"
        hedge_policy {
          initial_requests {
            value: 3
          }
          additional_request_chance {
            numerator: 4
          }
        }
      }
    }
    routes {
      match {
        prefix: "/bar"
      }
      route {
        cluster: "www"
      }
    }
    routes {
      match {
        prefix: "/"
      }
      route {
        cluster: "www"
        hedge_policy {
          initial_requests {
            value: 5
          }
          additional_request_chance {
            numerator: 40
          }
          hedge_on_per_try_timeout: true
        }
      }
    }
  }
}
headers {
  headers {
    key: ":authority"
    value: "www.lyft.com"
  }
  headers {
    key: ":path"
    value: "/bar"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
}
