goo.gle/debugproto
config {
  virtual_hosts {
    name: "path_prefix"
    domains: "*"
    routes {
      match {
        path_separated_prefix: "/rewrite"
      }
      route {
        cluster: "rewrite-cluster"
        prefix_rewrite: "/new/api"
      }
    }
    routes {
      match {
        prefix: "/"
      }
      route {
        cluster: "default-cluster"
      }
    }
  }
}
headers {
  headers {
    key: ":authority"
    value: "path.prefix.com"
  }
  headers {
    key: ":path"
    value: "/rewrite?param=true#fragment"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
}
