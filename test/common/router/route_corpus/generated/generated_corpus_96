goo.gle/debugproto
config {
  virtual_hosts {
    name: "path_prefix"
    domains: "*"
    routes {
      match {
        headers {
          name: "cookies"
        }
        query_parameters {
          name: "param"
          string_match {
            exact: "test"
          }
        }
        path_separated_prefix: "/rest/api"
      }
      route {
        cluster: "some-cluster"
      }
    }
    routes {
      match {
        prefix: "/"
      }
      route {
        cluster: "default"
      }
    }
  }
}
headers {
  headers {
    key: ":authority"
    value: "path.prefix.com"
  }
  headers {
    key: ":path"
    value: "/rest/api?param=testing"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
  headers {
    key: "cookies"
  }
}
