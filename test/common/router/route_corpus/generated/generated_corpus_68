goo.gle/debugproto
config {
  virtual_hosts {
    name: "www2"
    domains: "www.lyft.com"
    routes {
      match {
        prefix: "/foo"
      }
      route {
        cluster: "www2"
        retry_policy {
          retry_back_off {
            base_interval {
              nanos: 50000000
            }
          }
        }
      }
    }
    routes {
      match {
        prefix: "/bar"
      }
      route {
        cluster: "www2"
        retry_policy {
          retry_back_off {
            base_interval {
              nanos: 100000000
            }
            max_interval {
              nanos: 500000000
            }
          }
        }
      }
    }
    routes {
      match {
        prefix: "/baz"
      }
      route {
        cluster: "www2"
        retry_policy {
          retry_back_off {
            base_interval {
              nanos: 100000
            }
            max_interval {
              nanos: 100000
            }
          }
        }
      }
    }
    routes {
      match {
        prefix: "/"
      }
      route {
        cluster: "www2"
        retry_policy {
          retry_on: "connect-failure"
        }
      }
    }
  }
}
headers {
  headers {
    key: ":authority"
    value: "www.lyft.com"
  }
  headers {
    key: ":path"
    value: "/bar"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
}
