goo.gle/debugproto    
config {
  virtual_hosts {
    name: "local_service"
    domains: "*"
    routes {
      match {
        prefix: "/peer-cert-test"
        tls_context {
          presented {
            value: true
          }
        }
      }
      route {
        cluster: "server_peer-cert-presented"
      }
    }
    routes {
      match {
        prefix: "/peer-cert-test"
        tls_context {
          presented {
          }
        }
      }
      route {
        cluster: "server_peer-cert-not-presented"
      }
    }
    routes {
      match {
        prefix: "/peer-validated-cert-test"
        tls_context {
          validated {
            value: true
          }
        }
      }
      route {
        cluster: "server_peer-cert-validated"
      }
    }
    routes {
      match {
        prefix: "/peer-validated-cert-test"
        tls_context {
          validated {
          }
        }
      }
      route {
        cluster: "server_peer-cert-not-validated"
      }
    }
    routes {
      match {
        prefix: "/peer-cert-no-tls-context-match"
      }
      route {
        cluster: "server_peer-cert-no-tls-context-match"
      }
    }
    routes {
      match {
        prefix: "/"
      }
      route {
        cluster: "local_service_without_headers"
      }
    }
  }
}
headers {
  headers {
    key: ":authority"
    value: "www.lyft.com"
  }
  headers {
    key: ":path"
    value: "/peer-cert-test"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
}
