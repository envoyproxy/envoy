goo.gle/debugproto
config {
  virtual_hosts {
    name: "direct"
    domains: "example.com"
    routes {
      match {
        prefix: "/"
      }
      direct_response {
        status: 200
        body {
          inline_string: "content"
        }
      }
    }
  }
}
headers {
  headers {
    key: ":authority"
    value: "example.com"
  }
  headers {
    key: ":path"
    value: "/"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
}
