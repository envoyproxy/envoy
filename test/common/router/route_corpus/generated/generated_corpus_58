goo.gle/debugproto
config {
  name: "RequestMirrorPoliciesRouteConfiguration"
  virtual_hosts {
    name: "www"
    domains: "www.lyft.com"
    routes {
      match {
        prefix: "/foo"
      }
      route {
        cluster: "www"
        request_mirror_policies {
          cluster: "route_cluster"
        }
      }
    }
    routes {
      match {
        prefix: "/bar"
      }
      route {
        cluster: "www"
      }
    }
    request_mirror_policies {
      cluster: "vh_cluster"
    }
  }
  virtual_hosts {
    name: "www2"
    domains: "www2.lyft.com"
    routes {
      match {
        prefix: "/foo"
      }
      route {
        cluster: "www2"
        request_mirror_policies {
          cluster: "route_cluster"
        }
      }
    }
    routes {
      match {
        prefix: "/bar"
      }
      route {
        cluster: "www2"
      }
    }
  }
  request_mirror_policies {
    cluster: "rc_cluster"
  }
}
headers {
  headers {
    key: ":authority"
    value: "www.lyft.com"
  }
  headers {
    key: ":path"
    value: "/bar"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
}
