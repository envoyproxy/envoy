goo.gle/debugproto
config {
  virtual_hosts {
    name: "www2"
    domains: "www.lyft.com"
    routes {
      match {
        prefix: "/foo"
      }
      route {
        cluster: "www2"
        retry_policy {
          retry_on: "connect-failure"
        }
      }
    }
    routes {
      match {
        prefix: "/bar"
      }
      route {
        cluster: "www2"
      }
    }
    routes {
      match {
        prefix: "/"
      }
      route {
        cluster: "www2"
        retry_policy {
          retry_on: "5xx,gateway-error,connect-failure,reset"
          num_retries {
            value: 3
          }
          per_try_timeout {
            seconds: 1
          }
          per_try_idle_timeout {
            seconds: 5
          }
        }
      }
    }
  }
}
headers {
  headers {
    key: ":authority"
    value: "www.lyft.com"
  }
  headers {
    key: ":path"
    value: "/"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
}
