goo.gle/debugproto    
config {
  virtual_hosts {
    name: "exact"
    domains: "www.example.com"
    domains: "www.example.cc"
    domains: "wwww.example.com"
    routes {
      match {
        prefix: "/"
      }
      route {
        cluster: "exact"
      }
    }
  }
  virtual_hosts {
    name: "suffix"
    domains: "*w.example.com"
    routes {
      match {
        prefix: "/"
      }
      route {
        cluster: "suffix"
      }
    }
  }
  virtual_hosts {
    name: "prefix"
    domains: "www.example.c*"
    domains: "ww.example.c*"
    routes {
      match {
        prefix: "/"
      }
      route {
        cluster: "prefix"
      }
    }
  }
  virtual_hosts {
    name: "default"
    domains: "*"
    routes {
      match {
        prefix: "/"
      }
      route {
        cluster: "default"
      }
    }
  }
}
headers {
  headers {
    key: ":authority"
    value: "w.example.com"
  }
  headers {
    key: ":path"
    value: "/"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
}
