goo.gle/debugproto    
config {
  virtual_hosts {
    name: "www2"
    domains: "www.lyft.com"
    routes {
      match {
        prefix: "/endpoint"
      }
      route {
        cluster: "www2"
        timeout {
          seconds: 5
        }
      }
      request_headers_to_add {
        header {
          key: "x-timeout-copy"
          value: "%REQ(x-envoy-expected-rq-timeout-ms)%"
        }
      }
      request_headers_to_add {
        header {
          key: "x-attempt-copy"
          value: "%REQ(x-envoy-attempt-count)%"
        }
      }
    }
  }
}
headers {
  headers {
    key: ":authority"
    value: "www.lyft.com"
  }
  headers {
    key: ":path"
    value: "/endpoint"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
}
