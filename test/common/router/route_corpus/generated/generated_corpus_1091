goo.gle/debugproto    
config {
  virtual_hosts {
    name: "direct"
    domains: "direct.example.com"
    routes {
      match {
        prefix: "/"
      }
      direct_response {
        status: 200
        body {
          inline_string: ""
        }
      }
    }
  }
  max_direct_response_body_size_bytes {
    value: 8192
  }
}
headers {
  headers {
    key: ":authority"
    value: "direct.example.com"
  }
  headers {
    key: ":path"
    value: "/"
  }
  headers {
    key: ":scheme"
    value: "https"
  }
  headers {
    key: "x-forwarded-proto"
    value: "https"
  }
  headers {
    key: "x-envoy-internal"
    value: "false"
  }
}
