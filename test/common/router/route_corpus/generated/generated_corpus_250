goo.gle/debugproto
config {
  virtual_hosts {
    name: "default"
    domains: "*"
    routes {
      match {
        prefix: "/api"
      }
      route {
        cluster: "ats"
      }
      metadata {
        filter_metadata {
          key: "envoy.filters.http.router"
          value {
            fields {
              key: "name1"
              value {
                string_value: "value1"
              }
            }
            fields {
              key: "name2"
              value {
                string_value: "value2"
              }
            }
          }
        }
      }
    }
  }
}
headers {
  headers {
    key: ":authority"
    value: "api.lyft.com"
  }
  headers {
    key: ":path"
    value: "/api"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
}
