goo.gle/debugproto
config {
  virtual_hosts {
    name: "www"
    domains: "www.lyft.com"
    routes {
      match {
        prefix: "/no-backoff"
      }
      route {
        cluster: "www"
      }
    }
    routes {
      match {
        prefix: "/sub-ms-interval"
      }
      route {
        cluster: "www"
        retry_policy {
          rate_limited_retry_back_off {
            reset_headers {
              name: "Retry-After"
            }
            max_interval {
              nanos: 100000
            }
          }
        }
      }
    }
    routes {
      match {
        prefix: "/typical-backoff"
      }
      route {
        cluster: "www"
        retry_policy {
          rate_limited_retry_back_off {
            reset_headers {
              name: "Retry-After"
            }
            reset_headers {
              name: "RateLimit-Reset"
              format: UNIX_TIMESTAMP
            }
            max_interval {
              nanos: 50000000
            }
          }
        }
      }
    }
  }
}
headers {
  headers {
    key: ":authority"
    value: "www.lyft.com"
  }
  headers {
    key: ":path"
    value: "/typical-backoff"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
}
