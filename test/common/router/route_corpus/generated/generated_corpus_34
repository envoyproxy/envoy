goo.gle/debugproto
config {
  virtual_hosts {
    name: "local_service"
    domains: "*"
    routes {
      match {
        prefix: "/"
        headers {
          name: "test_header"
          string_match {
            exact: "test"
          }
        }
      }
      route {
        cluster: "local_service_with_headers"
      }
    }
    routes {
      match {
        prefix: "/"
        headers {
          name: "test_header_multiple1"
          string_match {
            exact: "test1"
          }
        }
        headers {
          name: "test_header_multiple2"
          string_match {
            exact: "test2"
          }
        }
      }
      route {
        cluster: "local_service_with_multiple_headers"
      }
    }
    routes {
      match {
        prefix: "/"
        headers {
          name: "test_header_presence"
          present_match: true
        }
      }
      route {
        cluster: "local_service_with_empty_headers"
      }
    }
    routes {
      match {
        prefix: "/"
        headers {
          name: "test_header_pattern"
          string_match {
            safe_regex {
              regex: "^user=test-\\d+$"
            }
          }
        }
      }
      route {
        cluster: "local_service_with_header_pattern_set_regex"
      }
    }
    routes {
      match {
        prefix: "/"
        headers {
          name: "test_header_pattern"
          string_match {
            exact: "^customer=test-\\d+$"
          }
        }
      }
      route {
        cluster: "local_service_with_header_pattern_unset_regex"
      }
    }
    routes {
      match {
        prefix: "/"
        headers {
          name: "test_header_range"
          range_match {
            start: 1
            end: 10
          }
        }
      }
      route {
        cluster: "local_service_with_header_range"
      }
    }
    routes {
      match {
        prefix: "/"
      }
      route {
        cluster: "local_service_without_headers"
      }
    }
  }
}
headers {
  headers {
    key: ":authority"
    value: "www.lyft.com"
  }
  headers {
    key: ":path"
    value: "/"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
  headers {
    key: "test_header_pattern"
    value: "user=test-1223"
  }
}
