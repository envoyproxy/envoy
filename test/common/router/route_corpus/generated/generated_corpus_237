goo.gle/debugproto    
config {
  virtual_hosts {
    name: "local_service"
    domains: "*"
    routes {
      match {
        path: "/path-bluh"
      }
      route {
        cluster: "local_service_grpc"
      }
      name: "business-specific-route"
    }
    routes {
      match {
        prefix: ""
      }
      route {
        cluster: "default-boring-service"
      }
      name: "catchall-route"
    }
  }
  ignore_path_parameters_in_path_matching: true
}
headers {
  headers {
    key: ":authority"
    value: "www.lyft.com"
  }
  headers {
    key: ":path"
    value: "/path-bluh;env=prod;ver=3?a=b;c=d#foo=bar"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
}
