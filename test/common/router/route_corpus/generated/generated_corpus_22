goo.gle/debugproto
config {
  virtual_hosts {
    name: "local_service"
    domains: "www.foo.com"
    domains: "12.34.56.78"
    domains: "[12:34:56:7890::]"
    routes {
      match {
        prefix: ""
      }
      route {
        cluster: "local_service_grpc"
      }
      name: "business-specific-route"
    }
  }
  virtual_hosts {
    name: "catchall_host"
    domains: "*"
    routes {
      match {
        prefix: ""
      }
      route {
        cluster: "default_catch_all_service"
      }
      name: "default-route"
    }
  }
  ignore_port_in_host_matching: true
}
headers {
  headers {
    key: ":authority"
    value: "[12:34:56:7890::]:8090"
  }
  headers {
    key: ":path"
    value: "/foo"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
}
