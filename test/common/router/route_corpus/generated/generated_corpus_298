goo.gle/debugproto    
config {
  virtual_hosts {
    name: "default_service"
    domains: "*"
    routes {
      match {
        prefix: "/"
      }
      route {
        cluster: "default_service"
      }
    }
  }
  virtual_hosts {
    name: "local_service"
    domains: "foo.example.org"
    routes {
      match {
        prefix: "/"
      }
      route {
        cluster: "local_service"
      }
    }
  }
  vhost_header: "alternate"
}
headers {
  headers {
    key: ":authority"
    value: "example.com"
  }
  headers {
    key: ":path"
    value: "/"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
  headers {
    key: "alternate"
    value: "foo.example.org"
  }
}
