goo.gle/debugproto    
config {
  virtual_hosts {
    name: "www2"
    domains: "lyft.com"
    matcher {
      matcher_tree {
        input {
          name: "request-headers"
          typed_config {
            [type.googleapis.com/envoy.type.matcher.v3.HttpRequestHeaderMatchInput] {
              header_name: ":path"
            }
          }
        }
        prefix_match_map {
          map {
            key: "/new_endpoint/bar"
            value {
              action {
                name: "route"
                typed_config {
                  [type.googleapis.com/envoy.config.route.v3.Route] {
                    match {
                      prefix: "/"
                    }
                    route {
                      cluster: "root_ww2"
                    }
                    request_headers_to_add {
                      header {
                        key: "x-route-header"
                        value: "match_tree_2"
                      }
                    }
                  }
                }
              }
            }
          }
          map {
            key: "/new_endpoint/foo"
            value {
              action {
                name: "route"
                typed_config {
                  [type.googleapis.com/envoy.config.route.v3.RouteList] {
                    routes {
                      match {
                        prefix: "/new_endpoint/foo/1"
                      }
                      route {
                        cluster: "root_ww2"
                      }
                      request_headers_to_add {
                        header {
                          key: "x-route-header"
                          value: "match_tree_1_1"
                        }
                      }
                    }
                    routes {
                      match {
                        prefix: "/new_endpoint/foo/2"
                      }
                      route {
                        cluster: "root_ww2"
                      }
                      request_headers_to_add {
                        header {
                          key: "x-route-header"
                          value: "match_tree_1_2"
                        }
                      }
                    }
                    routes {
                      match {
                        prefix: "/"
                        headers {
                          name: "x-match-header"
                          string_match {
                            exact: "matched"
                          }
                        }
                      }
                      route {
                        cluster: "root_ww2"
                      }
                      request_headers_to_add {
                        header {
                          key: "x-route-header"
                          value: "match_tree_1_3"
                        }
                      }
                    }
                    routes {
                      match {
                        prefix: "/something/else"
                      }
                      route {
                        cluster: "root_ww2"
                      }
                      request_headers_to_add {
                        header {
                          key: "x-route-header"
                          value: "match_tree_1_4"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
headers {
  headers {
    key: ":authority"
    value: "lyft.com"
  }
  headers {
    key: ":path"
    value: "/new_endpoint/bar"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
}
