goo.gle/debugproto
config {
  virtual_hosts {
    name: "bar"
    domains: "*"
    routes {
      match {
        safe_regex {
          regex: "/first"
        }
      }
      route {
        cluster: "ww2"
      }
      tracing {
        client_sampling {
          numerator: 1
        }
      }
    }
    routes {
      match {
        safe_regex {
          regex: "/second"
        }
      }
      route {
        cluster: "ww2"
      }
      tracing {
        overall_sampling {
          numerator: 1
        }
      }
    }
    routes {
      match {
        path: "/third"
      }
      route {
        cluster: "ww2"
      }
      tracing {
        client_sampling {
          numerator: 1
        }
        random_sampling {
          numerator: 200
          denominator: TEN_THOUSAND
        }
        overall_sampling {
          numerator: 3
        }
        custom_tags {
          tag: "ltag"
          literal {
            value: "lvalue"
          }
        }
        custom_tags {
          tag: "etag"
          environment {
            name: "E_TAG"
          }
        }
        custom_tags {
          tag: "rtag"
          request_header {
            name: "X-Tag"
          }
        }
        custom_tags {
          tag: "mtag"
          metadata {
            kind {
              route {
              }
            }
            metadata_key {
              key: "com.bar.foo"
              path {
                key: "xx"
              }
              path {
                key: "yy"
              }
            }
          }
        }
        operation: "%REQ(my-custom-downstream-operation)%"
        upstream_operation: "my-custom-fixed-upstream-operation"
      }
    }
  }
}
headers {
  headers {
    key: ":authority"
    value: "www.foo.com"
  }
  headers {
    key: ":path"
    value: "/first"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
}
