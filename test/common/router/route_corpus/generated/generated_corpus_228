goo.gle/debugproto    
config {
  virtual_hosts {
    name: "www2"
    domains: "www.lyft.com"
    routes {
      match {
        prefix: "/cacheable"
      }
      route {
        cluster: "www2"
      }
      response_headers_to_remove: "cache-control"
    }
    routes {
      match {
        prefix: "/"
      }
      route {
        cluster: "www2"
      }
    }
  }
  response_headers_to_add {
    header {
      key: "cache-control"
      value: "private"
    }
  }
  most_specific_header_mutations_wins: true
}
headers {
  headers {
    key: ":authority"
    value: "www.lyft.com"
  }
  headers {
    key: ":path"
    value: "/cacheable"
  }
  headers {
    key: ":method"
    value: "GET"
  }
  headers {
    key: ":scheme"
    value: "http"
  }
  headers {
    key: "x-safe"
    value: "safe"
  }
  headers {
    key: "x-global-nope"
    value: "global"
  }
  headers {
    key: "x-vhost-nope"
    value: "vhost"
  }
  headers {
    key: "x-route-nope"
    value: "route"
  }
  headers {
    key: "x-forwarded-proto"
    value: "http"
  }
}
