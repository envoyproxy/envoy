#!/usr/bin/env bash

set -e

export CXXFLAGS=''
export LDFLAGS=''

# AWS-LC FIPS build.
# https://github.com/aws/aws-lc/blob/main/crypto/fipsmodule/FIPS.md

OS=$(uname)
ARCH=$(uname -m)
# This works only on Linux-x86_64, Linux-ppc64le, and Linux-aarch64.

if [[ "$OS" != "Linux" || ("$ARCH" != "x86_64" && "$ARCH" != "aarch64" && "$ARCH" != "ppc64le") ]]; then
    echo "ERROR: AWS-LC FIPS is currently supported only on Linux-x86_64, Linux-ppc64le, and Linux-aarch64."
    exit 1
fi

# Execroot (read-only in sandbox). Build in writable $TMPDIR.
EXECROOT="$PWD"
BUILD_DIR=$(mktemp -d)
trap 'rm -rf $BUILD_DIR' EXIT

# Go needs GOCACHE in a writable dir (sandbox has no HOME)
export GOCACHE="$BUILD_DIR/gocache"
mkdir -p "$GOCACHE"
export HOME="$BUILD_DIR"

# Clang
export PATH="${CLANG_BIN_DIR}:$PATH"

# Toolchain file in writable dir
printf 'set(CMAKE_C_COMPILER "%s/clang")\nset(CMAKE_CXX_COMPILER "%s/clang++")\n' "$CLANG_BIN_DIR" "$CLANG_BIN_DIR" > "$BUILD_DIR/toolchain"

# Go
if [[ -n "${GOROOT:-}" ]]; then
    export PATH="${GOPATH}/bin:${GOROOT}/bin:${PATH}"
fi

# Ninja
export PATH="${NINJA_BIN_DIR}:$PATH"

# CMake
if [[ -n "${CMAKE_BIN_DIR:-}" ]]; then
    export PATH="${CMAKE_BIN_DIR}:${PATH}"
fi

# Copy source to writable dir (AWS-LC configure_file writes to source tree)
cp -rL "$EXECROOT/external/aws_lc" "$BUILD_DIR/aws_lc_src"

# Build in writable dir (sandbox-safe)
cd "$BUILD_DIR"
cmake -GNinja \
  -DCMAKE_TOOLCHAIN_FILE="$BUILD_DIR/toolchain" \
  -DFIPS=1 \
  -DCMAKE_BUILD_TYPE=Release \
  -DCMAKE_C_FLAGS="-fPIC" \
  -DCMAKE_CXX_FLAGS="-fPIC" \
  -S "$BUILD_DIR/aws_lc_src" \
  -B .
ninja
export GTEST_FILTER="-SSLTest.HostMatching"
./crypto/crypto_test

if [[ $(tool/bssl isfips) != "1" ]]; then
    echo "ERROR: BoringSSL tool didn't report FIPS build."
    exit 1
fi

cp "$BUILD_DIR/crypto/libcrypto.a" "$EXECROOT/$1"
cp "$BUILD_DIR/ssl/libssl.a" "$EXECROOT/$2"
