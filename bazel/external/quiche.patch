# Fix WebTransport detection on the client (sent) side.
#
# QuicSpdyStream::MaybeProcessSentWebTransportHeaders() decides whether an
# outgoing extended-CONNECT request is a WebTransport request. It must treat the
# request as WebTransport only when BOTH :method == "CONNECT" AND
# :protocol == "webtransport". The guard that skips non-WebTransport requests
# used `&&`, so it only skipped when the method was not CONNECT *and* the
# protocol was not webtransport. For an ordinary extended-CONNECT upgrade
# (e.g. `:method CONNECT`, `:protocol websocket`) the guard did not trigger and a
# spurious WebTransportHttp3 session was created on the stream, which then wrote
# WebTransport capsules onto the tunnel and routed response DATA frames into the
# capsule parser instead of delivering them as HTTP body.
#
# The receiving (server) side, MaybeProcessReceivedWebTransportHeaders(), already
# uses `||`; this makes the sent side match. This is a latent QUICHE bug, only
# reachable once WebTransport is negotiated (SupportsWebTransport()). Upstream it.
diff --git a/quiche/quic/core/http/quic_spdy_stream.cc b/quiche/quic/core/http/quic_spdy_stream.cc
--- a/quiche/quic/core/http/quic_spdy_stream.cc
+++ b/quiche/quic/core/http/quic_spdy_stream.cc
@@ -1457,6 +1457,6 @@ void QuicSpdyStream::MaybeProcessSentWebTransportHeaders(
   if (method_it == headers.end() || protocol_it == headers.end()) {
     return;
   }
-  if (method_it->second != "CONNECT" && protocol_it->second != "webtransport") {
+  if (method_it->second != "CONNECT" || protocol_it->second != "webtransport") {
     return;
   }
